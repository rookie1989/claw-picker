{
  "_comment": "OpenClaw 配置模板 - 基础版",
  "_version": "1.0.0",
  "_description": "复制此模板并根据你的需求修改",
  
  "gateway": {
    "port": 3000,
    "host": "0.0.0.0",
    "name": "My OpenClaw Gateway"
  },
  
  "channels": {
    "whatsapp": {
      "enabled": false,
      "name": "WhatsApp",
      "settings": {}
    },
    "telegram": {
      "enabled": false,
      "name": "Telegram",
      "token": "${TELEGRAM_BOT_TOKEN}",
      "settings": {}
    },
    "discord": {
      "enabled": false,
      "name": "Discord",
      "token": "${DISCORD_BOT_TOKEN}",
      "guildId": "",
      "settings": {}
    },
    "feishu": {
      "enabled": false,
      "name": "Feishu",
      "appId": "${FEISHU_APP_ID}",
      "appSecret": "${FEISHU_APP_SECRET}",
      "settings": {}
    }
  },
  
  "agent": {
    "model": "gpt-4",
    "provider": "openai",
    "apiKey": "${API_KEY}",
    "systemPrompt": "你是一个专业、友好的 AI 助手。",
    "temperature": 0.7,
    "maxTokens": 4000
  },
  
  "tools": {
    "enabled": [
      "read",
      "write",
      "edit",
      "exec",
      "web_search"
    ],
    "config": {}
  },
  
  "workspace": {
    "path": "~/openclaw-workspace",
    "autoCreate": true
  },
  
  "session": {
    "isolation": "channel",
    "storage": {
      "type": "local",
      "path": "~/.openclaw/sessions"
    }
  },
  
  "logging": {
    "level": "info",
    "format": "json",
    "output": {
      "console": true,
      "file": "~/.openclaw/logs/gateway.log"
    }
  }
}
